# Garud Kavach — Database Seed Script
# Copy this file to .env and fill in your values.

# Option 1: Full connection string (takes priority)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Option 2: Individual connection parameters (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=garudkavach
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_here

# Environment — set to "production" in deployed environments.
# Leave empty (or unset) for local development.
# In dev (HTTP), cookies are set without the Secure flag so the browser sends them.
# In production (HTTPS), Secure + SameSite=Strict are enforced.
APP_ENV=

# Redis (optional) — leave empty to use in-memory fallbacks.
# Example Upstash: redis://default:password@hostname.upstash.io:6379
REDIS_URL=

# Admin seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2a$10$...

# Admin signup security code
ADMIN_SECURITY_CODE=CHANGE_ME_LOCAL

# Gemini chatbot — primary key (required)
GEMINI_API_KEY=your_gemini_key_here
# Optional second key; used as fallback when the first key hits its rate limit
GEMINI_API_KEY_2=your_second_gemini_key_here

# Groq — final fallback when all Gemini key+model combinations fail
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# Phase 3 — File uploads (Cloudinary)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Phase 6 — Email (EmailJS)
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key

# Chat engine — uses the Gemini key above (GEMINI_API_KEY).
# No additional keys are required for the chat backend.
# Input constraints are enforced in code (not configurable via env):
#   Max message length: 2000 characters
#   Max history turns:  10 turns
