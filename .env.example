# Garud Kavach — Database Seed Script
# Copy this file to .env and fill in your values.

# Option 1: Full connection string (takes priority)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Option 2: Individual connection parameters (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=garudkavach
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_here

# Admin seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2a$10$...

# Admin signup security code
ADMIN_SECURITY_CODE=CHANGE_ME_LOCAL

# Gemini chatbot
GEMINI_API_KEY=your_gemini_key_here

# Phase 3 — File uploads (Cloudinary)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Phase 6 — Email (EmailJS)
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
